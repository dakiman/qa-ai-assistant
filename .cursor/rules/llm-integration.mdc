## Provider Abstraction

### ✅ Support multiple providers:
```python
class LLMService:
    def __init__(self):
        self.settings = get_settings()
        self._client = None
    
    @property
    def client(self):
        if self._client is None:
            if self.settings.llm_provider == "openai":
                self._client = instructor.from_openai(
                    OpenAI(api_key=self.settings.openai_api_key)
                )
            elif self.settings.llm_provider == "anthropic":
                self._client = instructor.from_anthropic(
                    Anthropic(api_key=self.settings.anthropic_api_key)
                )
            else:
                self._client = None  # Mock mode
        return self._client
    
    def generate(self, requirements: str) -> list[TestCaseDraft]:
        if self.client is None:
            return self._generate_mock(requirements)
        return self._generate_with_llm(requirements)
```

