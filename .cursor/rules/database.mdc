## Queries

### ✅ Use SQLModel select statements:
```python
from sqlmodel import select

# Simple query
def get_feature(session: Session, id: int) -> Optional[Feature]:
    return session.get(Feature, id)

# Query with filter
def get_features_by_status(session: Session, status: str) -> list[Feature]:
    statement = select(Feature).where(Feature.status == status)
    return session.exec(statement).all()

# Query with join (eager loading)
def get_feature_with_cases(session: Session, id: int) -> Optional[Feature]:
    statement = (
        select(Feature)
        .where(Feature.id == id)
        .options(selectinload(Feature.test_cases))
    )
    return session.exec(statement).first()

# Pagination
def list_features(session: Session, skip: int = 0, limit: int = 100) -> list[Feature]:
    statement = select(Feature).offset(skip).limit(limit)
    return session.exec(statement).all()
```

