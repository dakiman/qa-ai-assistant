## Model Definitions

### ✅ Correct SQLModel patterns:
```python
from datetime import datetime, timezone
from typing import Optional
from sqlmodel import SQLModel, Field, Relationship

class FeatureBase(SQLModel):
    """Base model with shared fields."""
    title: str = Field(index=True, max_length=255)
    description: Optional[str] = Field(default=None, max_length=5000)
    raw_requirements: str

class Feature(FeatureBase, table=True):
    """Database table model."""
    id: Optional[int] = Field(default=None, primary_key=True)
    created_at: datetime = Field(
        default_factory=lambda: datetime.now(timezone.utc)
    )
    
    # Relationships
    test_cases: list["TestCase"] = Relationship(
        back_populates="feature",
        sa_relationship_kwargs={"cascade": "all, delete-orphan"}
    )

class FeatureCreate(FeatureBase):
    """Request schema for creation."""
    pass

class FeatureRead(FeatureBase):
    """Response schema."""
    id: int
    created_at: datetime

class FeatureUpdate(SQLModel):
    """Partial update schema."""
    title: Optional[str] = None
    description: Optional[str] = None
    raw_requirements: Optional[str] = None
```

