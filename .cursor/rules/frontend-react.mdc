## State Management

### ❌ NEVER do this:
```tsx
// Duplicating prop in local state
function Card({ item }: { item: Item }) {
  const [currentItem, setCurrentItem] = useState(item);
  // Now state can drift from props!
}
```

### ✅ ALWAYS do this:
```tsx
// Use prop directly, let parent manage state
function Card({ item, onUpdate }: { item: Item; onUpdate: (item: Item) => void }) {
  const handleAction = async () => {
    const updated = await api.update(item.id);
    onUpdate(updated);  // Parent updates state
  };
}
```

