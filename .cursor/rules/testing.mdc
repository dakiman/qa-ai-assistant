## Frontend Testing (Jest + React Testing Library)

### Test File Structure
```
frontend/
├── __tests__/
│   ├── components/
│   │   ├── TestCaseCard.test.tsx
│   │   └── AddTestCaseDialog.test.tsx
│   └── pages/
│       └── features.test.tsx
└── jest.config.js
```

### Component Tests
```typescript
import { render, screen, fireEvent, waitFor } from '@testing-library/react';
import { TestCaseCard } from '@/components/TestCaseCard';

const mockTestCase = {
  id: 1,
  title: 'Test Case Title',
  steps: ['Step 1', 'Step 2'],
  expected_result: 'Expected result',
  status: 'draft' as const,
  is_edge_case: false,
  is_manual: false,
  feature_id: 1,
};

describe('TestCaseCard', () => {
  it('renders test case title', () => {
    render(<TestCaseCard testCase={mockTestCase} />);
    expect(screen.getByText('Test Case Title')).toBeInTheDocument();
  });

  it('shows accept and reject buttons for draft status', () => {
    render(<TestCaseCard testCase={mockTestCase} />);
    expect(screen.getByText('Accept')).toBeInTheDocument();
    expect(screen.getByText('Reject')).toBeInTheDocument();
  });

  it('calls onStatusChange when accepting', async () => {
    const onStatusChange = jest.fn();
    render(
      <TestCaseCard 
        testCase={mockTestCase} 
        onStatusChange={onStatusChange} 
      />
    );
    
    fireEvent.click(screen.getByText('Accept'));
    
    await waitFor(() => {
      expect(onStatusChange).toHaveBeenCalledWith(
        expect.objectContaining({ status: 'accepted' })
      );
    });
  });

  it('shows edge case badge when is_edge_case is true', () => {
    render(
      <TestCaseCard 
        testCase={{ ...mockTestCase, is_edge_case: true }} 
      />
    );
    expect(screen.getByText('Edge')).toBeInTheDocument();
  });
});
```

### API Mocking
```typescript
import { rest } from 'msw';
import { setupServer } from 'msw/node';

const server = setupServer(
  rest.get('/api/v1/features', (req, res, ctx) => {
    return res(ctx.json([
      { id: 1, title: 'Feature 1', raw_requirements: 'req' }
    ]));
  }),
  rest.post('/api/v1/test-cases/:id/accept', (req, res, ctx) => {
    return res(ctx.json({
      ...mockTestCase,
      status: 'accepted'
    }));
  })
);

beforeAll(() => server.listen());
afterEach(() => server.resetHandlers());
afterAll(() => server.close());
```

