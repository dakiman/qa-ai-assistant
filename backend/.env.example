# Backend configuration. Copy to `.env` and edit as needed.
# Defaults work out of the box in mock-LLM mode (no API key required).

# LLM provider: mock | openai | anthropic | openrouter
LLM_PROVIDER=mock

# API keys — only the one matching LLM_PROVIDER is needed.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional model overrides (sensible current defaults are set in config.py).
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-5
# OPENAI_VALIDATION_MODEL=gpt-4o-mini
# ANTHROPIC_VALIDATION_MODEL=claude-haiku-4-5
# OpenRouter needs a real slug that supports tool calling (instructor uses it):
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Database — SQLite for dev, PostgreSQL for prod (needs psycopg2-binary).
DATABASE_URL=sqlite:///./qa_craft.db

# Environment: development | staging | production
ENVIRONMENT=development

# Run Alembic migrations on startup.
AUTO_MIGRATE=true

# Two-stage requirements validation (rule-based + cheap LLM check).
VALIDATION_ENABLED=true

# Optional write auth. If set, all mutating requests require this key via the
# X-API-Key header. The Dockerized frontend proxy injects it server-side, so the
# frontend's API_KEY must match this value. Leave blank to disable auth.
API_KEY=

# Also require auth on read endpoints.
REQUIRE_AUTH_FOR_READS=false

# Comma-separated allowed CORS origins (only matters when the browser calls the
# backend cross-origin; the Docker setup is same-origin via the proxy).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Rate limiting for the expensive LLM endpoints (generate / refine). Set
# RATE_LIMIT_ENABLED=false to disable (e.g. tests). Values use slowapi/limits
# syntax, e.g. "10/minute" or "100/hour;10/minute".
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERATE=10/minute
RATE_LIMIT_REFINE=15/minute
