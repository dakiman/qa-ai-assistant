# Frontend configuration. Copy to `.env.local` and edit as needed.

# Base URL the browser uses for API calls. Keep the relative proxy path so
# requests go through the Next.js server (src/app/api/v1/[...path]/route.ts),
# which injects the write key server-side. Only override for native dev if you
# want the browser to hit the backend directly (e.g. http://localhost:8000/api/v1).
NEXT_PUBLIC_API_URL=/api/v1

# Where the server-side proxy forwards requests. In Docker this is the api
# service name; natively it's the local backend.
BACKEND_URL=http://localhost:8000

# Server-only write key the proxy injects as X-API-Key. Must match the backend
# API_KEY. NOT prefixed with NEXT_PUBLIC_, so it never reaches the client bundle.
# Leave blank if the backend has no API_KEY set.
API_KEY=
